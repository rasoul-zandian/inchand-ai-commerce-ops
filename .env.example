# Copy to .env and fill in values as features are wired up.
# Step 1: no runtime secrets required.

# --- LangSmith observability ---
# Set LANGSMITH_TRACING=true to enable tracing of LangGraph / LangChain runs.
# Never commit real API keys; keep secrets in .env (gitignored) or a secret manager.
# For production later, prefer a dedicated LangSmith service key with least privilege.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=inchand-ai-commerce-mvp

# --- LLM (provider-agnostic layer; nodes call app.llm factory) ---
# mock is the default for local safe development.
# openai can be enabled later by setting LLM_PROVIDER=openai and OPENAI_API_KEY (after factory wiring).
# Never commit real API keys.
# Loaded at runtime by pydantic-settings (see app/config.py); OS environment overrides these lines.
LLM_PROVIDER=mock
LLM_MODEL=mock-vendor-ticket-drafter
# Only needed when LLM_PROVIDER=openai. Never commit real keys.
OPENAI_API_KEY=

# Future: Anthropic / Claude — not implemented in app.llm.factory yet; document only.

# --- Future: PostgreSQL + pgvector ---
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/inchand_ai
