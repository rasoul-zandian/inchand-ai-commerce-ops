# Copy to .env and fill in values as features are wired up.
# Step 1: no runtime secrets required.

# --- LangSmith observability ---
# Set LANGSMITH_TRACING=true to enable tracing of LangGraph / LangChain runs.
# Never commit real API keys; keep secrets in .env (gitignored) or a secret manager.
# For production later, prefer a dedicated LangSmith service key with least privilege.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=inchand-ai-commerce-mvp

# --- Operator review actions (intake API persistence adapter) ---
# noop = accept actions without storage (default)
# memory = in-process store for local test/dev only
REVIEW_ACTION_ADAPTER=noop

# --- LLM (provider-agnostic layer; nodes call app.llm factory) ---
# mock is the default for local safe development.
# openai can be enabled later by setting LLM_PROVIDER=openai and OPENAI_API_KEY (after factory wiring).
# Never commit real API keys.
# Loaded at runtime by pydantic-settings (see app/config.py); OS environment overrides these lines.
LLM_PROVIDER=mock
LLM_MODEL=mock-vendor-ticket-drafter
# Only needed when LLM_PROVIDER=openai. Never commit real keys.
OPENAI_API_KEY=

# --- Embeddings (provider-agnostic; used for future semantic RAG) ---
# mock is the default for local development.
# openai can be used later with EMBEDDING_PROVIDER=openai and OPENAI_API_KEY (see app/embeddings/factory.py).
# Never commit real API keys.
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=mock-embedding-small

# Retrieval strategy for workflow context loading.
# mock = deterministic catalog retrieval (default)
# semantic = semantic similarity over local runtime vector store
# policy_only = only policy documents
# approved_examples = only approved response examples
RAG_STRATEGY=mock
# Number of documents requested during workflow retrieval (default 5).
RAG_TOP_K=5
# Optional retrieval profile. If set, it controls strategy/top_k/embedding settings.
# Values: mock, policy_only, approved_examples, semantic_local,
# semantic_pgvector_16, semantic_pgvector, custom
# Leave empty to use individual RAG_STRATEGY/RAG_TOP_K/EMBEDDING_* fields.
RAG_PROFILE=

# Local pgvector 16-D smoke profile (requires db init + indexed corpus):
# RAG_PROFILE=semantic_pgvector_16
# VECTOR_STORE_PROVIDER=pgvector
# PGVECTOR_TABLE=rag_vector_records_16
# PGVECTOR_DIMENSIONS=16
# PGVECTOR_DATABASE_URL=postgresql://inchand:inchand_dev_password@127.0.0.1:5432/inchand_ai

# Production-like pgvector staging profile (manual/staging only; do not enable in CI):
# RAG_PROFILE=semantic_pgvector
# VECTOR_STORE_PROVIDER=pgvector
# PGVECTOR_TABLE=rag_vector_records
# PGVECTOR_DIMENSIONS=1536
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_KEY=
# Requires corpus indexed with the same embedding provider/model/dimensions.

# Future: Anthropic / Claude — not implemented in app.llm.factory yet; document only.

# --- Vector store provider (pgvector opt-in; default memory) ---
# memory: default for CI and semantic_local. pgvector: semantic_pgvector* profiles only.
VECTOR_STORE_PROVIDER=memory
# Only needed when VECTOR_STORE_PROVIDER=pgvector.
PGVECTOR_DATABASE_URL=
PGVECTOR_TABLE=rag_vector_records
PGVECTOR_DIMENSIONS=1536

# For staging pg-compare, compare PgVector against in-memory baseline using same embeddings.
# BASELINE_PROVIDER=same_embedding

# --- Retrieval quality gates (pg-eval / pg-compare; manual staging only; not in CI) ---
# RETRIEVAL_QUALITY_GATES=true
# RETRIEVAL_MIN_PASS_RATE=1.0
# RETRIEVAL_MIN_MEAN_RECALL_AT_K=1.0
# RETRIEVAL_MIN_MEAN_HIT_RATE=1.0
# RETRIEVAL_MIN_MEAN_MRR=1.0
# RETRIEVAL_MAX_PASS_RATE_REGRESSION=0.0
# RETRIEVAL_MAX_MEAN_RECALL_AT_K_REGRESSION=0.0
# RETRIEVAL_MAX_MEAN_HIT_RATE_REGRESSION=0.0
# RETRIEVAL_MAX_MEAN_MRR_REGRESSION=0.0
# RETRIEVAL_REQUIRE_MATCHING_CASE_RESULTS=true
# Optional near-miss ranking gates for staging (unset = disabled; does not change eval pass/fail):
# RETRIEVAL_MAX_NEAR_MISS_VIOLATIONS=0
# RETRIEVAL_MAX_NEAR_MISS_VIOLATION_REGRESSION=0

# --- Strict staging retrieval quality profile (optional; do NOT enable by default) ---
# Intended for manual/staging pg-eval + pg-compare before promoting semantic_pgvector. Not used in CI.
# export RETRIEVAL_QUALITY_GATES=true
# export RETRIEVAL_MIN_PASS_RATE=1.0
# export RETRIEVAL_MIN_MEAN_RECALL_AT_K=1.0
# export RETRIEVAL_MIN_MEAN_HIT_RATE=1.0
# export RETRIEVAL_MIN_MEAN_MRR=0.8
# export RETRIEVAL_MAX_PASS_RATE_REGRESSION=0.0
# export RETRIEVAL_MAX_MEAN_RECALL_AT_K_REGRESSION=0.0
# export RETRIEVAL_MAX_MEAN_HIT_RATE_REGRESSION=0.0
# export RETRIEVAL_MAX_MEAN_MRR_REGRESSION=0.05
# export RETRIEVAL_REQUIRE_MATCHING_CASE_RESULTS=true
# export RETRIEVAL_MAX_NEAR_MISS_VIOLATIONS=0
# export RETRIEVAL_MAX_NEAR_MISS_VIOLATION_REGRESSION=0

# --- Local Postgres (manual staging; not used in make ci) ---
# PGVECTOR_DATABASE_URL=postgresql://inchand:inchand_dev_password@127.0.0.1:5432/inchand_ai
# See README: make pg-up, pg-init, pg-index — then RAG_PROFILE=semantic_pgvector*
